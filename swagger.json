    "/api/v2/Stocks/asyncid": {
      "get": {
        "tags": ["Stocks"],
        "summary": "Lấy data Kho theo asyncID",
        "description": "Lấy data Kho theo async_id",
        "parameters": [
          {
            "name": "async_ids",
            "in": "query",
            "description": "list async id Kho",
            "schema": {
