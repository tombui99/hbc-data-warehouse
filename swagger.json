          {
            "name": "page",
            "in": "query",
            "description": "Trang muốn xem",
            "schema": {
              "type": "integer",
              "description": "Trang muốn xem",
              "format": "int32"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Số bản ghi trên 1 trang",
            "schema": {
              "type": "integer",
              "description": "Số bản ghi trên 1 trang",
              "format": "int32",
              "default": 10
            }
          },
          {
            "name": "orderBy",
            "in": "query",
            "description": "Sắp xếp theo",
            "schema": {
              "type": "string",
              "description": "Sắp xếp theo",
              "default": "modified_date",
              "nullable": true
            }
          },
          {
            "name": "isDescending",
            "in": "query",
            "description": "Giảm dần",
            "schema": {
              "type": "boolean",
              "description": "Giảm dần",
              "default": true
            }
          },
          {
            "name": "Clientid",
            "in": "header",
            "description": "Mã ứng dụng đăng ký trên crm",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseV2"
                }
              }
            }
          }
        }
      }
    },
